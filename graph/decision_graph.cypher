// Glasswork decision + custody graph — load into Neo4j / AuraDB
// Usage: cypher-shell < decision_graph.cypher   (or paste into Neo4j Browser)
CREATE CONSTRAINT IF NOT EXISTS FOR (m:Model) REQUIRE m.id IS UNIQUE;
CREATE CONSTRAINT IF NOT EXISTS FOR (d:Doc) REQUIRE d.id IS UNIQUE;
CREATE CONSTRAINT IF NOT EXISTS FOR (r:Run) REQUIRE r.id IS UNIQUE;
CREATE CONSTRAINT IF NOT EXISTS FOR (c:CustodyRoot) REQUIRE c.model_id IS UNIQUE;
CREATE CONSTRAINT IF NOT EXISTS FOR (x:Decision) REQUIRE x.id IS UNIQUE;
