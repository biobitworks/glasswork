MERGE (x:Decision {id:"ceiling"}) SET x.kind="verdict", x.label="Custody proves provenance of the recorded run — not correctness, not reproducibility. An LLM verdict is a signal, never a custody proof.";
MERGE (x:Decision {id:"commit-floor"}) SET x.kind="commitment", x.label="Pass bar fixed BEFORE running: precision ≥ 0.80 AND recall ≥ 0.75";
MERGE (x:Decision {id:"dec-chosen"}) SET x.kind="decision", x.label="Selected google/gemma-3-27b-it — cheapest passing model on this corpus";
MERGE (x:Decision {id:"dec-rule"}) SET x.kind="decision", x.label="Trusted model = the cheapest model that clears the pass bar";
MERGE (x:Decision {id:"learn-json"}) SET x.kind="learning", x.label="The 70B Llama emitted invalid JSON on 1 of 2 docs — unusable by an automated pipeline";
MERGE (x:Decision {id:"learn-precision"}) SET x.kind="learning", x.label="Every model that returned valid output scored 100% precision — no ungrounded spans survived";
MERGE (x:Decision {id:"learn-size"}) SET x.kind="learning", x.label="Model size did NOT predict recall: 27B Gemma (0.9375) beat the 70B and 120B models";
MATCH (x:Decision {id:"dec-chosen"}),(m:Model {id:"google/gemma-3-27b-it"}) MERGE (x)-[:SELECTED]->(m);
MERGE (z:Citation {doi:"10.5281/zenodo.21210575"}) SET z.title="Fractal Custody Objects: route-comparable chain-of-custody for deterministic computational biology and AI-agent provenance";
MATCH (x:Decision {id:"ceiling"}),(z:Citation {doi:"10.5281/zenodo.21210575"}) MERGE (x)-[:CITES]->(z);
